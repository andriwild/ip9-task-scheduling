<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="MainTree">
    <Parallel>
      <EventHandler queue="{queue}" goal="{goal}"/>
      <RobotState robot_task="{robot_task}"/>
      <NavigateToPoint goal="{goal}" _skipIf="goal == -1"/>
    </Parallel>
  </BehaviorTree>
</root>
