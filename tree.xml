     <root BTCPP_format="4">
         <BehaviorTree ID="MainTree">
            <Fallback>
                <Subtree ID="SearchRoutine"/>
                <Subtree ID="EscortRoutine"/>
                <Subtree ID="IdleRoutine"/>
            </Fallback>
         </BehaviorTree>

        <BehaviorTree ID="SearchRoutine">
            <Sequence>
                <IsSearching/>
                <Fallback>
                    <Sequence>
                        <ScanLocation/>
                        <StartEscortConversation/> 
                    </Sequence>
                    <Sequence>
                        <HasNextLocation/>  
                        <MoveToNextLocation/>
                    </Sequence>
                    <AbortSearch/> 
                </Fallback>
            </Sequence>
        </BehaviorTree>


        <BehaviorTree ID="EscortRoutine">
            <Sequence>
                <IsEscorting/>
                <Fallback>
                    <Sequence>
                        <ArrivedWithPerson/>
                        <StartConversation/> 
                    </Sequence>
                    <AbortEscort/>
                </Fallback>
            </Sequence>
        </BehaviorTree>


        <BehaviorTree ID="IdleRoutine">
            <Sequence>
                <Docking/>
                <EnterIdle/>
            </Sequence>
        </BehaviorTree>
        </root>
