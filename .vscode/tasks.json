{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build_debug",
            "type": "shell",
            "command": "colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Debug --packages-select event_system_core",
            "options": {
                "cwd": "${workspaceFolder}/ros2_ws"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "detail": "Builds the event_system_core package with debug symbols."
        }
    ]
}