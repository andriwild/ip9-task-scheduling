{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Event System Core",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/ros2_ws/install/event_system_core/lib/event_system_core/event_system_core",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/ros2_ws",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build_debug"
        },
        {
            "name": "ROS: Launch",
            "type": "ros",
            "request": "launch",
            "target": "${workspaceFolder}/ros2_ws/src/event_system_bringup/launch/bringup.launch.py"
        }
    ]
}